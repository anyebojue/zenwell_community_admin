{
  "name": "zenwell_admin",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "prepare": "mkdir -p .husky && git config core.hooksPath .husky",
    "build": "cross-env NODE_ENV=production rspack build",
    "check": "biome check --write",
    "dev": "cross-env NODE_ENV=development rspack serve",
    "format": "biome format --write",
    "lint": "eslint src"
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "^1.0.1",
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@fontsource-variable/dm-sans": "^5.1.0",
    "@fontsource/barlow": "^5.1.0",
    "@fontsource/dm-sans": "^5.1.0",
    "@fontsource/roboto": "^5.1.0",
    "@mui/icons-material": "^6.1.7",
    "@mui/material": "^6.1.7",
    "@mui/styled-engine-sc": "^6.1.7",
    "@mui/x-charts": "^7.22.2",
    "@mui/x-data-grid": "^7.22.2",
    "@mui/x-data-grid-pro": "^7.22.2",
    "@mui/x-date-pickers": "^7.22.2",
    "@mui/x-date-pickers-pro": "^7.22.2",
    "@mui/x-tree-view": "^7.22.1",
    "@react-spring/web": "^9.7.5",
    "@reduxjs/toolkit": "^2.3.0",
    "axios": "^1.7.7",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.53.2",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.28.0",
    "styled-components": "^6.1.13"
  },
  "devDependencies": {
    "@amap/amap-jsapi-types": "^0.0.15",
    "@biomejs/biome": "^1.9.3",
    "@commitlint/cli": "^19.5.0",
    "@commitlint/config-conventional": "^19.5.0",
    "@eslint/compat": "^1.2.0",
    "@eslint/js": "^9.12.0",
    "@rspack/cli": "^1.1.1",
    "@rspack/core": "^1.1.1",
    "@rspack/plugin-react-refresh": "1.0.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.2",
    "@types/webpack-bundle-analyzer": "^4.7.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.16.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "file-loader": "^6.2.0",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "react-refresh": "^0.14.0",
    "style-loader": "^4.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,d.ts,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css,less}": [
      "prettier --write"
    ]
  }
}
