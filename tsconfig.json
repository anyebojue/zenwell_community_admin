{
  "compilerOptions": {
    "baseUrl": "src",
    "target": "ES2020",
    "lib": [
      "DOM",
      "ES2020",
      "esnext"
    ],
    "module": "ESNext",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true
  },
  "include": [
    "src",
    "rspack.config.ts"
  ],
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}